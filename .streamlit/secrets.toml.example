# ============================================================
# Streamlit Secrets TEMPLATE
# ------------------------------------------------------------
# 1. LOCAL run:  copy this file to ".streamlit/secrets.toml"
#                and fill in your real values.
# 2. CLOUD run:  paste the same content into
#                Streamlit Cloud -> your app -> Settings -> Secrets
#
# NOTE: secrets.toml is git-ignored, so your real keys are never committed.
# ============================================================

[gmail]
# Paste the ENTIRE contents of the OAuth client JSON you download
# from Google Cloud Console (OAuth 2.0 Client ID, type = "Web application").
credentials_json = '''
{
  "web": {
    "client_id": "YOUR-CLIENT-ID.apps.googleusercontent.com",
    "project_id": "your-project-id",
    "auth_uri": "https://accounts.google.com/o/oauth2/auth",
    "token_uri": "https://oauth2.googleapis.com/token",
    "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
    "client_secret": "YOUR-CLIENT-SECRET",
    "redirect_uris": ["http://localhost:8501"]
  }
}
'''

# The redirect URI MUST exactly match one of the "Authorized redirect URIs"
# you added in Google Cloud Console.
#   - Local development:  "http://localhost:8501"
#   - Streamlit Cloud:    "https://YOUR-APP-NAME.streamlit.app"
redirect_uri = "http://localhost:8501"
